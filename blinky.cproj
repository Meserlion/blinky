<?xml version="1.0" encoding="utf-8"?>
<Project DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <SchemaVersion>2.0</SchemaVersion>
    <ProjectVersion>6.0</ProjectVersion>
    <ToolchainName>com.Atmel.AVRGCC8.CPP</ToolchainName>
    <ProjectGuid>{12345678-1234-1234-1234-123456789ABC}</ProjectGuid>
    <avrdevice>ATmega328P</avrdevice>
    <avrdeviceseries>mega</avrdeviceseries>
    <OutputFileExtension>.elf</OutputFileExtension>
    <ReferencesPath></ReferencesPath>
    <Language>CPP</Language>
    <OutputFileName>$(MSBuildProjectName)</OutputFileName>
    <OutputFileExtension>.elf</OutputFileExtension>
    <OutputDirectory>$(MSBuildProjectDirectory)\$(Configuration)</OutputDirectory>
    <AssemblyName>blinky</AssemblyName>
    <Name>blinky</Name>
    <RootNamespace>blinky</RootNamespace>
    <ToolchainFlavour>Native</ToolchainFlavour>
    <AsfFrameworkConfig></AsfFrameworkConfig>
    <avrtool>com.atmel.avrdbg.tool.simulator</avrtool>
    <com_atmel_avrdbg_tool_simulator>
      <ToolOptions>
        <InterfaceProperties></InterfaceProperties>
      </ToolOptions>
      <ToolType>Simulator</ToolType>
      <ToolNumber></ToolNumber>
      <ToolName>Simulator</ToolName>
    </com_atmel_avrdbg_tool_simulator>
    <avrtoolinterface>ISP</avrtoolinterface>
    <avrtoolinterfaceclock>200000</avrtoolinterfaceclock>
    <AsfFrameworkConfig></AsfFrameworkConfig>
    <LastSavedToolchainFlavour>Native</LastSavedToolchainFlavour>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)' == 'Debug' ">
    <ToolchainSettings>
      <AvrGppCompiler>
        <avrgpp.compiler.general.ChangeDefaultCharTypeUnsigned>False</avrgpp.compiler.general.ChangeDefaultCharTypeUnsigned>
        <avrgpp.compiler.general.ChangeDefaultBitFieldUnsigned>False</avrgpp.compiler.general.ChangeDefaultBitFieldUnsigned>
        <avrgpp.compiler.symbols.DefSymbols>
          <ListValues>
            <Value>DEBUG</Value>
          </ListValues>
        </avrgpp.compiler.symbols.DefSymbols>
        <avrgpp.compiler.optimization.level>Optimization_O1</avrgpp.compiler.optimization.level>
        <avrgpp.compiler.optimization.PackStructureMembers>True</avrgpp.compiler.optimization.PackStructureMembers>
        <avrgpp.compiler.optimization.AllocateBytesNeededForEnum>True</avrgpp.compiler.optimization.AllocateBytesNeededForEnum>
        <avrgpp.compiler.optimization.EnableUnsafemath>False</avrgpp.compiler.optimization.EnableUnsafemath>
        <avrgpp.compiler.optimization.DebugLevel>Maximum</avrgpp.compiler.optimization.DebugLevel>
        <avrgpp.compiler.warning.EnablewarningGw>False</avrgpp.compiler.warning.EnablewarningGw>
        <avrgpp.compiler.warning.EnableWarningAll>True</avrgpp.compiler.warning.EnableWarningAll>
        <avrgpp.compiler.warning.EnableWarningExtra>False</avrgpp.compiler.warning.EnableWarningExtra>
      </AvrGppCompiler>
      <AvrLinker>
        <avrgpp.linker.general.EnableRelaxation>False</avrgpp.linker.general.EnableRelaxation>
        <avrgpp.linker.general.UseNewlibNano>True</avrgpp.linker.general.UseNewlibNano>
        <avrgpp.linker.general.AdditionalLibs>
          <ListValues></ListValues>
        </avrgpp.linker.general.AdditionalLibs>
        <avrgpp.linker.general.AdditionalLibraryDirectories>
          <ListValues></ListValues>
        </avrgpp.linker.general.AdditionalLibraryDirectories>
        <avrgpp.linker.general.GenerateMAPFile>True</avrgpp.linker.general.GenerateMAPFile>
      </AvrLinker>
      <AvrAssembler>
        <avrgpp.assembler.general.IncludePaths>
          <ListValues></ListValues>
        </avrgpp.assembler.general.IncludePaths>
      </AvrAssembler>
    </ToolchainSettings>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)' == 'Release' ">
    <ToolchainSettings>
      <AvrGppCompiler>
        <avrgpp.compiler.general.ChangeDefaultCharTypeUnsigned>False</avrgpp.compiler.general.ChangeDefaultCharTypeUnsigned>
        <avrgpp.compiler.general.ChangeDefaultBitFieldUnsigned>False</avrgpp.compiler.general.ChangeDefaultBitFieldUnsigned>
        <avrgpp.compiler.symbols.DefSymbols>
          <ListValues></ListValues>
        </avrgpp.compiler.symbols.DefSymbols>
        <avrgpp.compiler.optimization.level>Optimization_Os</avrgpp.compiler.compiler.optimization.level>
        <avrgpp.compiler.optimization.PackStructureMembers>True</avrgpp.compiler.optimization.PackStructureMembers>
        <avrgpp.compiler.optimization.AllocateBytesNeededForEnum>True</avrgpp.compiler.optimization.AllocateBytesNeededForEnum>
        <avrgpp.compiler.optimization.EnableUnsafemath>False</avrgpp.compiler.optimization.EnableUnsafemath>
        <avrgpp.compiler.optimization.DebugLevel>None</avrgpp.compiler.optimization.DebugLevel>
        <avrgpp.compiler.warning.EnablewarningGw>False</avrgpp.compiler.warning.EnablewarningGw>
        <avrgpp.compiler.warning.EnableWarningAll>True</avrgpp.compiler.warning.EnableWarningAll>
        <avrgpp.compiler.warning.EnableWarningExtra>False</avrgpp.compiler.warning.EnableWarningExtra>
      </AvrGppCompiler>
      <AvrLinker>
        <avrgpp.linker.general.EnableRelaxation>False</avrgpp.linker.general.EnableRelaxation>
        <avrgpp.linker.general.UseNewlibNano>True</avrgpp.linker.general.UseNewlibNano>
        <avrgpp.linker.general.AdditionalLibs>
          <ListValues></ListValues>
        </avrgpp.linker.general.AdditionalLibs>
        <avrgpp.linker.general.AdditionalLibraryDirectories>
          <ListValues></ListValues>
        </avrgpp.linker.general.AdditionalLibraryDirectories>
        <avrgpp.linker.general.GenerateMAPFile>True</avrgpp.linker.general.GenerateMAPFile>
      </AvrLinker>
      <AvrAssembler>
        <avrgpp.assembler.general.IncludePaths>
          <ListValues></ListValues>
        </avrgpp.assembler.general.IncludePaths>
      </AvrAssembler>
    </ToolchainSettings>
  </PropertyGroup>
  <ItemGroup>
    <Compile Include="main.cpp">
      <SubType>compile</SubType>
    </Compile>
  </ItemGroup>
  <Import Project="$(AVRSTUDIO_EXE_PATH)\\..\\Vs\\Compiler.targets" />
</Project>
